# Copy this file to `.env` and adjust values.
# The scripts read from process env. Use your shell export,
# dotenv runner, or your preferred secret manager.

# Optional when already authenticated with `codex login`.
# CODEX_API_KEY=sk-...

# Optional custom API base URL for proxy/self-hosted routing.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Global thread safety defaults for demo scripts.
# Keep these safe for live workshops unless you explicitly need edits.
CODEX_SANDBOX_MODE=read-only
CODEX_APPROVAL_POLICY=never
CODEX_NETWORK_ACCESS_ENABLED=false
# Optional: request raw reasoning items in thread events (best-effort).
CODEX_SHOW_RAW_AGENT_REASONING=false

# Set to true only for non-git workshop folders.
SKIP_GIT_REPO_CHECK=false

# Persistent worker settings.
WORKER_ENABLED=true
WORKER_INTERVAL_MINUTES=30
WORKER_PROMPT=Scan the project and produce a concise engineering check-in with top 3 actionable next steps.
WORKER_MAX_RESPONSE_CHARS=1000

# PR reviewer defaults.
# Override repo on command line or set here for quick demos.
PR_REVIEW_REPO=rudrankriyam/Foundation-Models-Framework-Example
# Path to a markdown file with your custom review instructions.
# Defaults to pr-review-instructions.md in the project root.
# PR_REVIEW_INSTRUCTIONS_FILE=pr-review-instructions.md

# PR poller worker (08-pr-review-poller.ts).
# Continuously checks open PRs and runs demo:pr-review automatically.
PR_POLL_ENABLED=true
PR_POLL_REPO=rudrankriyam/Foundation-Models-Framework-Example
PR_POLL_INTERVAL_SECONDS=300
PR_POLL_MAX_REVIEWS_PER_CYCLE=2
# Modes:
# - auto: review when PR updated since last review
# - trigger: review only when a new trigger comment is posted
PR_POLL_MODE=auto
PR_POLL_TRIGGER_PHRASE=@codex-review
PR_POLL_INCLUDE_DRAFTS=false
# For demos/testing: run one cycle and exit.
PR_POLL_RUN_ONCE=false

# Slack coworker (06-slack-coworker.ts).
# Create a Slack App at https://api.slack.com/apps with Socket Mode enabled.
# Bot token scopes: app_mentions:read, chat:write, im:history, im:read, im:write
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
